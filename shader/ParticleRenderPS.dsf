//STAGE:ps
#include "Common.dsh"

[SpecializationConstant] bool g_HasTex = false;

Texture2D particle_tex;
float4 main(
	in float2 iTc 		: TEXCOORD,
	in float4 iColor	: COLOR) : SV_Target
{
if (g_HasTex)
{
	float4 sColor = particle_tex.Sample(linear_sampler, iTc);
	return iColor * sColor;
}
else
{
	return iColor;
}
}